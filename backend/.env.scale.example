# Copy these into backend/.env for million-user production profile
# Then run: npm run scale:indexes (once) + npm run production + npm run worker

SCALE_MODE=production
NODE_ENV=production

# Redis (required)
REDIS_URL=redis://:YOUR_PASSWORD@redis:6379
REDIS_ENABLED=true
QUEUE_ENABLED=true
MESSAGE_ASYNC=true

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/hustlex
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_READ_PREF=secondaryPreferred

# S3 + CDN uploads (required for multiple API pods)
S3_ENABLED=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=hustlex-uploads
AWS_REGION=us-east-1
CDN_URL=https://cdn.yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com

# Email at scale (Amazon SES — not Gmail)
EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@yourdomain.com

# Security
JWT_SECRET=use-a-64-char-random-secret-here-minimum-32-chars
CLIENT_URL=https://yourdomain.com

# Optional: fail startup if scale config invalid
# SCALE_STRICT=true

# Production Environment — copy to backend/.env before cloud deploy
# Local scale dev: keep NODE_ENV=development, use npm run scale:redis + worker

SCALE_MODE=production
NODE_ENV=production
PORT=5000

# MongoDB Atlas (M30+ for 100k+, sharded for 1M+ DAU)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hustlex?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_READ_PREF=secondaryPreferred

# Redis (required — Docker: redis://redis:6379)
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true
QUEUE_ENABLED=true
MESSAGE_ASYNC=true
MESSAGE_QUEUE_TIMEOUT_MS=8000

# Auth — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_USE_CRYPTO_RANDOM
JWT_EXPIRE=7d
ADMIN_CODE=CHANGE_ME

# Frontend
CLIENT_URL=https://yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com

# Email at scale (Amazon SES)
EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# S3 + CDN (required for multiple API pods)
S3_ENABLED=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=hustlex-uploads
AWS_REGION=us-east-1
AWS_S3_PUBLIC_URL_BASE=https://hustlex-uploads.s3.amazonaws.com
CDN_URL=https://cdn.yourdomain.com
CLOUDFRONT_DISTRIBUTION_ID=

# Uploads
MAX_FILE_SIZE=10485760

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Strict mode — exit if Redis/JWT invalid in production
# SCALE_STRICT=true

# Optional monitoring
# SENTRY_DSN=

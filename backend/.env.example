# HustleX Backend Environment Variables
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/hustlex

# JWT Secret (generate a secure one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_secure_jwt_secret_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Redis (optional - disable for development if not using)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
QUEUE_ENABLED=false
MESSAGE_ASYNC=false

# Email (optional - disable if not using)
EMAIL_ENABLED=false
EMAIL_PROVIDER=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@hustlex.com
ADMIN_EMAIL=admin@hustlex.com

# AWS S3 (optional - for file uploads)
S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=hustlex-uploads
AWS_REGION=us-east-1
